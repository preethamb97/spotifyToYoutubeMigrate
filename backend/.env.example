# Server Configuration
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/musicbridge

# Session Secret (change this to a random string in production)
SESSION_SECRET=your_session_secret_here

# Logging Configuration
LOG_LEVEL=info
NODE_ENV=development

# Firebase Configuration (from Firebase Console > Project Settings > Service Accounts)
# Create project at: https://console.firebase.google.com/
# Enable Google sign-in provider in Authentication > Sign-in method
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Note: Replace newlines in private key with \n when pasting

# Spotify OAuth (Playlist read access)
# Create at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_CALLBACK_URL=http://localhost:5000/auth/spotify/callback

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173
